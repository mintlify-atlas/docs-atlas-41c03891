  "keyFeatures": [
    "28 dashboard panels for comprehensive agent orchestration",
    "Real-time WebSocket and SSE monitoring with smart polling",
    "Kanban task board with drag-and-drop, priorities, and assignments",
    "Token usage and cost tracking with per-model breakdowns",
    "Role-based access control with viewer, operator, and admin roles",
    "Direct CLI integration without gateway requirements",
    "Multi-gateway connection management",
    "Background scheduler for automated tasks and cleanups",
    "Agent SOUL system with workspace file sync",
    "GitHub Issues sync with label and assignee mapping",
    "Outbound webhooks with delivery history and retry logic",
    "Quality review gates for task sign-off",
    "Pipeline orchestration with workflow templates",
    "Claude Code session tracking and auto-discovery"
  ],
  "publicApiSurface": [
    "POST /api/auth/login - Login with username/password",
    "POST /api/auth/logout - Destroy session",
    "GET /api/agents - List agents with task stats",
    "POST /api/agents - Register/update agent",
    "GET /api/agents/[id] - Agent details",
    "GET /api/tasks - List tasks with filters",
    "POST /api/tasks - Create task",
    "PUT /api/tasks/[id] - Update task",
    "GET /api/status - System status (uptime, memory, disk)",
    "GET /api/activities - Activity feed",
    "GET /api/tokens - Token usage and cost data",
    "GET /api/sessions - Active gateway sessions",
    "POST /api/connect - Register direct CLI connection",
    "POST /api/agents/[id]/heartbeat - Agent heartbeat with token reporting",
    "GET /api/events - SSE stream of database changes",
    "GET /api/webhooks - List webhooks",
    "POST /api/webhooks - Create webhook",
    "GET /api/alerts - List alert rules",
    "POST /api/spawn - Spawn agent session",
    "GET /api/claude/sessions - List Claude Code sessions",
    "POST /api/pipelines/run - Start pipeline",
    "GET /api/workflows - List workflow templates",
    "GET /api/settings - App settings",
    "POST /api/backup - Database backup",
    "GET /api/audit - Audit log"
  ]
}
